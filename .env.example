# Upstream company API
COMPANY_API_URL=https://backend.raycast.com/api/v1/ai/chat_completions
COMPANY_MODELS_API_URL=https://backend.raycast.com/api/v1/ai/models
COMPANY_API_KEY=
REQUEST_TIMEOUT_SECONDS=120
LOG_REQUEST_SUMMARY=false
DEBUG_REQUEST_BODY=false
DEBUG_REQUEST_BODY_MAX_CHARS=4000
DEBUG_UPSTREAM_STREAM=false
DEBUG_UPSTREAM_MAX_CHARS=500

# Default company request fields
DEFAULT_PROVIDER=google
DEFAULT_LOCALE=en-CN
DEFAULT_SOURCE=quick_ai
DEFAULT_SYSTEM_INSTRUCTION=markdown
DEFAULT_DEBUG=false

# Raycast-style request signing
RAYCAST_SIGNATURE_ENABLED=true
# raycast_sig_v2.py: DEFAULT_TRANSFORMED_JWT_SECRET
RAYCAST_SIGNING_SECRET=
RAYCAST_SIGNING_SECRET_TRANSFORMED=true
# raycast_sig_v2.py: DEFAULT_DEVICE_TAG
RAYCAST_DEVICE_ID=
# raycast_sig_v2.py: DEFAULT_ANONYMOUS_ID
RAYCAST_ANONYMOUS_ID=
RAYCAST_JWT_EXPIRES_IN=60

# Raycast-compatible upstream headers
RAYCAST_EXPERIMENTAL="autoModels, chatBranching, mcpHTTPServer"
RAYCAST_USER_AGENT="Raycast/1.104.19 (macOS Version 26.5 (Build 25F71))"
RAYCAST_ACCEPT_LANGUAGE="zh-CN,zh-Hans;q=0.9"
RAYCAST_PRIORITY="u=3"
